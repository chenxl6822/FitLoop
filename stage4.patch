@@ -0,0 +1,67 @@
+import 'dart:async';
+import 'dart:io';
+
+/// 网络连通性监听。
+///
+/// 通过定期 DNS 解析或 HTTP 探测检查实际可达性（而非仅 wifi/4G 图标）。
+class ConnectivityService {
+  ConnectivityService({this.probeUrl = 'https://httpbin.org/get'});
+
+  final String probeUrl;
+  StreamController<bool>? _controller;
+  Timer? _timer;
+
+  /// 当前是否在线（最近一次探测结果）。
+  bool _online = true;
+  bool get isOnline => _online;
+
+  /// 事件流：true → 上线，false → 离线。
+  Stream<bool> get onStatusChange {
+    _controller ??= StreamController<bool>.broadcast();
+    return _controller!.stream;
+  }
+
+  /// 开始定期探测（默认每 15 秒一次）。
+  void start({Duration interval = const Duration(seconds: 15)}) {
+    _timer?.cancel();
+    _probe();
+    _timer = Timer.periodic(interval, (_) => _probe());
+  }
+
+  /// 停止探测。
+  void stop() {
+    _timer?.cancel();
+    _timer = null;
+  }
+
+  /// 立即执行一次探测，返回当前在线状态。
+  Future<bool> check() => _probe();
+
+  Future<bool> _probe() async {
+    try {
+      final client = HttpClient();
+      client.connectionTimeout = const Duration(seconds: 5);
+      final request = await client.getUrl(Uri.parse(probeUrl));
+      final response = await request.close();
+      final ok = response.statusCode == 200;
+      if (ok != _online) {
+        _online = ok;
+        _controller?.add(ok);
+      }
+      client.close(force: true);
+      return ok;
+    } catch (_) {
+      if (_online) {
+        _online = false;
+        _controller?.add(false);
+      }
+      return false;
+    }
+  }
+
+  void dispose() {
+    stop();
+    _controller?.close();
+    _controller = null;
+  }
+}
diff --git a/mobile/lib/local_cache.dart b/mobile/lib/local_cache.dart
new file mode 100644
index 0000000..fe216cc
--- /dev/null
+++ b/mobile/lib/local_cache.dart
@@ -0,0 +1,143 @@
+import 'package:shared_preferences/shared_preferences.dart';
+
+/// 本地持久化缓存：会话 + 目标 + 统计数据 + 历史记录。
+///
+/// 所有值以 JSON 字符串存入 SharedPreferences，附带缓存时间戳。
+class LocalCache {
+  LocalCache._();
+
+  // ──────── Session keys ────────
+  static const _kToken = 'token';
+  static const _kUid = 'uid';
+  static const _kNickname = 'nickname';
+
+  // ──────── Data cache keys ────────
+  static const _kTargets = 'cache_targets';
+  static const _kStats = 'cache_stats';
+  static const _kHistory = 'cache_history';
+  static const _kWeightHistory = 'cache_weight_history';
+
+  /// 每个 cache key 对应一个专属的缓存时间 key。
+  static String _timeKey(String dataKey) => '${dataKey}_at';
+
+  // ════════════════════════════════════════════
+  //  Session management（向后兼容 TokenStorage）
+  // ════════════════════════════════════════════
+
+  static Future<void> saveSession(
+      String token, int userId, String nickname) async {
+    final p = await SharedPreferences.getInstance();
+    await p.setString(_kToken, token);
+    await p.setInt(_kUid, userId);
+    await p.setString(_kNickname, nickname);
+  }
+
+  static Future<Map<String, Object>?> loadSession() async {
+    final p = await SharedPreferences.getInstance();
+    final t = p.getString(_kToken);
+    if (t == null || t.isEmpty) return null;
+    return {
+      'token': t,
+      'userId': p.getInt(_kUid) ?? 0,
+      'nickname': p.getString(_kNickname) ?? 'FitLoop 用户',
+    };
+  }
+
+  static Future<void> clearSession() async {
+    final p = await SharedPreferences.getInstance();
+    await p.remove(_kToken);
+    await p.remove(_kUid);
+    await p.remove(_kNickname);
+  }
+
+  /// 一次性清除所有缓存（含会话）。
+  static Future<void> clearAll() async {
+    final p = await SharedPreferences.getInstance();
+    for (final k in <String>[
+      _kToken,
+      _kUid,
+      _kNickname,
+      _kTargets,
+      _kStats,
+      _kHistory,
+      _kWeightHistory,
+      _timeKey(_kTargets),
+      _timeKey(_kStats),
+      _timeKey(_kHistory),
+      _timeKey(_kWeightHistory),
+    ]) {
+      await p.remove(k);
+    }
+  }
+
+  // ════════════════════════════════════════════
+  //  Typed cache helpers
+  // ════════════════════════════════════════════
+
+  // ──── Goals / targets ────
+
+  static Future<void> cacheTargetsJson(String json) =>
+      _writeJson(_kTargets, json);
+
+  static Future<String?> getCachedTargetsJson() =>
+      _readString(_kTargets);
+
+  // ──── Sport stats summary ────
+
+  static Future<void> cacheStatsJson(String json) =>
+      _writeJson(_kStats, json);
+
+  static Future<String?> getCachedStatsJson() =>
+      _readString(_kStats);
+
+  // ──── Sport history ────
+
+  static Future<void> cacheHistoryJson(String json) =>
+      _writeJson(_kHistory, json);
+
+  static Future<String?> getCachedHistoryJson() =>
+      _readString(_kHistory);
+
+  // ──── Weight history ────
+
+  static Future<void> cacheWeightHistoryJson(String json) =>
+      _writeJson(_kWeightHistory, json);
+
+  static Future<String?> getCachedWeightHistoryJson() =>
+      _readString(_kWeightHistory);
+
+  // ════════════════════════════════════════════
+  //  Freshness check
+  // ════════════════════════════════════════════
+
+  /// 如果 [cacheKey] 对应的缓存在上次写入后不超过 [maxAge] 则认为「新鲜」。
+  static Future<bool> isFresh(String cacheKey,
+      {Duration maxAge = const Duration(hours: 1)}) async {
+    final p = await SharedPreferences.getInstance();
+    final raw = p.getInt(_timeKey(cacheKey));
+    if (raw == null) return false;
+    final age = DateTime.now().millisecondsSinceEpoch - raw;
+    return age < maxAge.inMilliseconds;
+  }
+
+  /// 直接读 Data 缓存的过期时间戳（毫秒），-1 表示从未缓存。
+  static Future<int> cacheTimestampMs(String cacheKey) async {
+    final p = await SharedPreferences.getInstance();
+    return p.getInt(_timeKey(cacheKey)) ?? -1;
+  }
+
+  // ════════════════════════════════════════════
+  //  Internal
+  // ════════════════════════════════════════════
+
+  static Future<void> _writeJson(String key, String json) async {
+    final p = await SharedPreferences.getInstance();
+    await p.setString(key, json);
+    await p.setInt(_timeKey(key), DateTime.now().millisecondsSinceEpoch);
+  }
+
+  static Future<String?> _readString(String key) async {
+    final p = await SharedPreferences.getInstance();
+    return p.getString(key);
+  }
+}
