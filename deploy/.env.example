MYSQL_DATABASE=fitloop
MYSQL_USER=fitloop
MYSQL_PASSWORD=fitloop
MYSQL_ROOT_PASSWORD=fitloop-root
FITLOOP_JWT_SECRET=replace-with-a-long-random-production-secret
FITLOOP_AGENT_SERVICE_KEY=replace-with-a-random-agent-service-key
FITLOOP_AGENT_DELEGATION_SECRET=replace-with-a-random-agent-delegation-secret
FITLOOP_AGENT_ENABLED=true
# Set both values for one startup only, then clear both after the existing user is promoted to ADMIN.
FITLOOP_ADMIN_BOOTSTRAP_ACCOUNT=
FITLOOP_ADMIN_BOOTSTRAP_NICKNAME=
DEEPSEEK_API_KEY=replace-with-a-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_COACH_MODEL=deepseek-v4-flash
DEEPSEEK_APPEAL_MODEL=deepseek-v4-pro
FLASH_INPUT_USD_PER_MILLION=0.14
FLASH_OUTPUT_USD_PER_MILLION=0.28
PRO_INPUT_USD_PER_MILLION=0.435
PRO_OUTPUT_USD_PER_MILLION=0.87
FITLOOP_OTP_HASH_SECRET=replace-with-a-long-random-otp-hash-secret
FITLOOP_OTP_DEBUG_RETURN=false
FITLOOP_MAIL_HOST=smtp.qq.com
FITLOOP_MAIL_PORT=465
FITLOOP_MAIL_USERNAME=
FITLOOP_MAIL_PASSWORD=replace-with-qq-mail-smtp-authorization-code
FITLOOP_MAIL_FROM=
FITLOOP_TLS_ENABLED=false
FITLOOP_HTTP_COMPAT_ENABLED=true
FITLOOP_TLS_CERT_FILE=/etc/letsencrypt/live/your-domain.example/fullchain.pem
FITLOOP_TLS_KEY_FILE=/etc/letsencrypt/live/your-domain.example/privkey.pem
FITLOOP_PUBLIC_BASE_URL=https://your-domain.example
SERVER_PORT=8080
